<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MatrixIncBezorgApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MatrixIncBezorgApp"
    Title="MatrixIncBezorgApp">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Packages"
        ContentTemplate="{DataTemplate local:PackagesToScanPage}"
        Route="PackagesToScanPage" />

    <ShellContent
        Title="Summary"
        ContentTemplate="{DataTemplate local:SummaryPage}"
        Route="SummaryPage" />

</Shell>
