<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MatrixIncBezorgApp.ConfirmDelivery"
             Title="ConfirmDelivery">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Frame Grid.Row="0"
               BackgroundColor="Yellow"
               BorderColor="LightGray"
               Padding="10"
               Margin="10">

            <HorizontalStackLayout
                Spacing="20"
                HorizontalOptions="Center">

                <Image Source="truck.png"
                       HeightRequest="28"/>

                <Image Source="loading.png"
                       HeightRequest="28"/>


                <Image Source="barcode.png"
                        HeightRequest="28"/>

                <Image Source="express_delivery.png"
                       HeightRequest="28"/>
      
                <Frame BackgroundColor="LightSkyBlue"
                       Padding="5"
                       CornerRadius="6">
      
                    <Image Source="delivery.png"
                       HeightRequest="28"/>

                </Frame>

            </HorizontalStackLayout>

        </Frame>
    </Grid>
</ContentPage>