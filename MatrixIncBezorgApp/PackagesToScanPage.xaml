<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MatrixIncBezorgApp.Models"
             x:Class="MatrixIncBezorgApp.PackagesToScanPage"
             Title="Packages to Scan">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <Label Grid.Row="0" 
               Text="Packages to Collect" 
               FontSize="24" 
               FontAttributes="Bold" 
               Margin="0,0,0,15" />

        <CollectionView Grid.Row="1" x:Name="packagesList">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PackageItem">
                    <Frame Margin="0,0,0,10" Padding="15" CornerRadius="8" BackgroundColor="#E8F5E9" HasShadow="False">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding PackageId}" FontSize="18" FontAttributes="Bold" TextColor="#2E7D32" />
                                <Label Text="Package ID" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                                <Label Text="{Binding RackLocation}" FontSize="18" FontAttributes="Bold" TextColor="#1565C0" HorizontalOptions="End" />
                                <Label Text="Rack" FontSize="12" TextColor="Gray" HorizontalOptions="End" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
