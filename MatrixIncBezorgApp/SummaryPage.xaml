<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MatrixIncBezorgApp.Models"
             x:Class="MatrixIncBezorgApp.SummaryPage"
             Title="Summary">

    <Grid RowDefinitions="*, *" Padding="20">

        <!-- Still Need To Scan -->
        <VerticalStackLayout Grid.Row="0">
            <Label Text="Still Need To Scan" FontSize="20" FontAttributes="Bold" Margin="0,0,0,10" TextColor="#D32F2F" />
            <CollectionView x:Name="missingPackagesList">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PackageItem">
                        <Frame Margin="0,0,0,5" Padding="10" CornerRadius="8" BackgroundColor="#FFEBEE" HasShadow="False">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="{Binding PackageId}" FontSize="16" FontAttributes="Bold" />
                                <Label Grid.Column="1" Text="{Binding RackLocation}" FontSize="14" TextColor="Gray" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Scanned -->
        <VerticalStackLayout Grid.Row="1" Margin="0,20,0,0">
            <Label Text="Already Scanned" FontSize="20" FontAttributes="Bold" Margin="0,0,0,10" TextColor="#388E3C" />
            <CollectionView x:Name="scannedPackagesList">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:PackageItem">
                        <Frame Margin="0,0,0,5" Padding="10" CornerRadius="8" BackgroundColor="#E8F5E9" HasShadow="False">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="{Binding PackageId}" FontSize="16" FontAttributes="Bold" />
                                <Label Grid.Column="1" Text="{Binding RackLocation}" FontSize="14" TextColor="Gray" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

    </Grid>

</ContentPage>
