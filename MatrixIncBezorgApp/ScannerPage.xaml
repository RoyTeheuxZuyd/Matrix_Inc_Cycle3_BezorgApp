<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="MatrixIncBezorgApp.ScannerPage"
             Title="Barcode Scanner">

    <Grid RowDefinitions="*,*">
        <zxing:CameraBarcodeReaderView
            Grid.Row="0"
            x:Name="barcodeReader"
            BarcodesDetected="CameraBarcodeReaderView_BarcodesDetected" />

        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" Padding="15">
            <Label Grid.Row="0" Text="Scanned Packages" FontAttributes="Bold" FontSize="18" Padding="0,0,0,10" />

            <CollectionView Grid.Row="1" x:Name="scannedList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10" Margin="0,0,0,5" CornerRadius="5" BackgroundColor="#F0F0F0" HasShadow="False">
                            <Label Text="{Binding .}" FontSize="16" TextColor="Black" />
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Grid.Row="2" 
                    Text="Close"
                    HorizontalOptions="Center"
                    Margin="10"
                    Clicked="CloseButton_Clicked" />
        </Grid>
    </Grid>
</ContentPage>