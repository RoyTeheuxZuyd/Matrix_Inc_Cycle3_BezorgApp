<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MatrixIncBezorgApp.MeldingPage"
             Title="Melding">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="#FFF8E1"
                   BorderColor="#F4C542"
                   Padding="15"
                   CornerRadius="10">

                <VerticalStackLayout Spacing="10">
                    <Label Text="Onderstaande afbeelding toont de beoogde uitwerking van de meldingsfunctionaliteit."
                           FontSize="15"
                           TextColor="Black"/>
                </VerticalStackLayout>
            </Frame>

            <Image Source="melding_mockup.jpg"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"
                   Margin="0,10,0,20"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>